---
import { getCollection } from 'astro:content';
import EntryList from '../../components/EntryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { canonicalEntries, isPublished } from '../../lib/content';

const posts = canonicalEntries((await getCollection('blog')).filter(isPublished));
---

<BaseLayout title="Blog" description="Polished technical posts from Garage Notes.">
	<section class="page-heading">
		<p class="eyebrow">Blog</p>
		<h1>Longer Notes</h1>
		<p class="lead">Polished technical posts, written after enough of the problem has stopped moving.</p>
	</section>
	<EntryList entries={posts} emptyText="No blog posts published yet." />
</BaseLayout>
