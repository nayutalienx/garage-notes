---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { entryUrl, isPublished } from '../../lib/content';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter(isPublished);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: {
			post,
			translations: post.data.translationKey
				? posts
						.filter(
							(candidate) =>
								candidate.id !== post.id &&
								candidate.data.translationKey === post.data.translationKey,
						)
						.map((candidate) => ({
							language: candidate.data.language,
							title: candidate.data.title,
							url: entryUrl(candidate),
						}))
				: [],
		},
	}));
}
type Props = {
	post: CollectionEntry<'blog'>;
	translations: Array<{
		language: 'en' | 'ru';
		title: string;
		url: string;
	}>;
};

const { post, translations } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} translations={translations}>
	<Content />
</BlogPost>
