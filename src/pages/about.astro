---
import BaseLayout from '../layouts/BaseLayout.astro';
import { REPO_URL } from '../consts';
import { withBase } from '../lib/content';
---

<BaseLayout title="About" description="About Garage Notes.">
	<section class="page-heading">
		<p class="eyebrow">About</p>
		<h1>Garage Notes</h1>
		<p class="lead">A public engineering notebook for practical work, unfinished experiments, and technical dead ends.</p>
	</section>

	<div class="prose">
		<p>
			This site is for publishing while the garage door is still up: small notes first, better essays
			when a topic has earned them. The default language is English, with Russian allowed when the
			topic is mainly local or Russian-speaking.
		</p>
		<p>
			I write about Windows internals, security experiments, networking, developer tooling, and
			notes from unfinished engineering work.
		</p>
		<p>
			The public version should keep useful reasoning and remove private details. Secrets, private
			infrastructure, personal data, and copy-paste abuse instructions do not belong here.
		</p>
		<ul>
			<li><a href={REPO_URL} target="_blank" rel="noreferrer">GitHub</a></li>
			<li><a href={withBase('rss.xml')}>RSS</a></li>
			<li><a href="mailto:nayutalienx@gmail.com">Email</a></li>
			<li><a href="https://t.me/nayutalienx" target="_blank" rel="noreferrer">Telegram</a></li>
			<li><a href="https://x.com/mugiwara_byte" target="_blank" rel="noreferrer">X</a></li>
		</ul>
	</div>
</BaseLayout>
