---
import type { CollectionEntry } from 'astro:content';
import ContentEntry from './ContentEntry.astro';

type TranslationLink = {
	language: 'en' | 'ru';
	title: string;
	url: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	translations?: TranslationLink[];
};

const { title, description, pubDate, updatedDate, tags, language, translations = [] } = Astro.props;
---

<ContentEntry
	title={title}
	description={description}
	pubDate={pubDate}
	updatedDate={updatedDate}
	tags={tags}
	language={language}
	translations={translations}
	kind="Blog"
>
	<slot />
</ContentEntry>
