---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	lang?: 'en' | 'ru';
	ogType?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
}

const {
	title,
	description,
	lang = 'en',
	ogType = 'website',
	pubDate,
	updatedDate,
	tags = [],
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			ogType={ogType}
			pubDate={pubDate}
			updatedDate={updatedDate}
			tags={tags}
		/>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
